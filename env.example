# FastCode Environment Variables

OPENAI_API_KEY=your_openai_api_key_here
MODEL=your_model
BASE_URL=your_base_url

# OPENAI_API_KEY=your_openai_api_key_here
# MODEL=google/gemini-3-flash-preview
# BASE_URL=https://openrouter.ai/api/v1

# Ollama
# OPENAI_API_KEY=ollama
# MODEL=qwen3-coder-30b_fastcode
# BASE_URL=http://localhost:11434/v1

# Optional: persist HuggingFace/sentence-transformers cache to avoid re-downloads
HF_HOME=./fastcode_data/hf-cache
HUGGINGFACE_HUB_CACHE=./fastcode_data/hf-cache/hub
TRANSFORMERS_CACHE=./fastcode_data/hf-cache/transformers
SENTENCE_TRANSFORMERS_HOME=./fastcode_data/hf-cache/sentence-transformers


# ===== Nanobot Model (Agent Reasoning / Feishu Conversations) =====
NANOBOT_MODEL=minimax/minimax-m2.1
